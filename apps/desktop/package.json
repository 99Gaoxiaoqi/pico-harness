{
  "name": "@pico/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package && node ../../scripts/desktop-package-smoke.mjs",
    "make": "electron-forge make && node ../../scripts/desktop-package-smoke.mjs",
    "pretypecheck": "npm run build --workspace @pico/protocol",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.preload.json && tsc --noEmit -p tsconfig.renderer.json",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@pico/protocol": "*",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "better-sqlite3": "^12.11.1",
    "lucide-react": "^1.24.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.0",
    "jsdom": "^29.1.1",
    "vite": "^8.1.4"
  }
}
