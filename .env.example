# ============================================================
# pico-harness 环境变量配置模板
# 复制本文件为 .env 并填入真实值:.env 已被 gitignore,不会提交
# ============================================================

# --- 大模型 API (必填) ---
# 支持 OpenAI 兼容协���与 Anthropic Claude 协议的第三方端点
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key-here
# 可选:多凭证轮换(逗号分隔,复数)。配置后 429 限流时自动切换下一个 key,
# 优先级高于 LLM_API_KEY(单数)。单 key 时无需配置,行为不变。
# LLM_API_KEYS=sk-key1,sk-key2,sk-key3
# 模型名(需与端点支持的模型一致)
LLM_MODEL=glm-5.2

# --- 飞书机器人 (可选,仅 --feishu 模式需要) ---
# 在飞书开放平台创建应用后获得
FEISHU_APP_ID=cli_your_app_id
FEISHU_APP_SECRET=your_app_secret
# 事件订阅加密与校验(在飞书应用后台「事件订阅」页配置,可选)
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFY_TOKEN=
# 飞书 HTTP 回调监听端口(可选,WSClient 长连接模式不需要)
FEISHU_PORT=3457

# --- 日志级别 (可选) ---
# 控制引擎内部日志输出级别:debug / info / warn / error,默认 info
LOG_LEVEL=info
