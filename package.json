{
  "name": "pico-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "description": "A TypeScript Agent Harness built lesson by lesson from the《从0开始构建Agent Harness》course.",
  "bin": {
    "pico": "./dist/cli/main.js"
  },
  "files": [
    "dist"
  ],
  "bundleDependencies": [
    "@pico/protocol"
  ],
  "scripts": {
    "predev": "npm run build:protocol",
    "dev": "tsx --env-file-if-exists=.env --import ./src/tui/preload-env.ts src/cli/main.ts",
    "desktop:dev": "npm run start --workspace @pico/desktop",
    "desktop:package": "npm run package --workspace @pico/desktop",
    "desktop:make": "npm run make --workspace @pico/desktop",
    "desktop:typecheck": "npm run typecheck --workspace @pico/desktop",
    "mobile:gateway": "npm run build:protocol && tsx --env-file-if-exists=.env src/mobile-gateway/main.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build:protocol": "npm run build --workspace @pico/protocol",
    "prebuild": "npm run clean && npm run build:protocol",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "node -e \"require('node:fs').chmodSync('dist/cli/main.js',0o755)\"",
    "prepack": "npm run build",
    "pretypecheck": "npm run build:protocol",
    "typecheck": "tsc --noEmit",
    "pretest:integration": "npm run build:protocol",
    "test:integration": "node --import tsx --import ./src/tui/preload-env.ts --test --test-concurrency=1 tests/integration/*.test.ts",
    "pretest:integration:windows": "npm run build:protocol",
    "test:integration:windows": "node --import tsx --import ./src/tui/preload-env.ts --test --test-concurrency=1 tests/integration/windows/hook-security.test.ts tests/integration/windows/file-write-dacl.test.ts tests/integration/windows/yolo-shell-hardline.test.ts",
    "pretest:llm-e2e": "npm run build:protocol",
    "test:llm-e2e": "node --env-file-if-exists=.env --import tsx --import ./src/tui/preload-env.ts --test --test-concurrency=1 tests/e2e/runtime-consistency.real-llm.test.ts",
    "check:storage": "node scripts/check-storage-capability.mjs",
    "check:architecture": "node scripts/check-architecture-boundaries.mjs",
    "check:architecture:strict": "node scripts/check-architecture-boundaries.mjs --strict",
    "lint": "eslint src scripts tests 'apps/**/*.{ts,tsx}' 'packages/**/*.{ts,tsx}' eslint.config.js --no-error-on-unmatched-pattern && npm run check:architecture",
    "format": "prettier --check src scripts tests apps packages .github/workflows docs README.md AGENTS.md package.json package-lock.json tsconfig.json tsconfig.build.json"
  },
  "engines": {
    "node": ">=22.12 <23"
  },
  "dependencies": {
    "@pico/protocol": "*",
    "better-sqlite3": "^12.11.1",
    "gpt-tokenizer": "^3.4.0",
    "ink": "^7.1.0",
    "js-yaml": "^5.1.0",
    "marked": "^18.0.6",
    "pathe": "^2.0.3",
    "picocolors": "^1.1.1",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "string-width": "^8.2.1",
    "wrap-ansi": "^10.0.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/ws": "^8.18.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "@electron/rebuild": "4.2.0",
    "external-editor": {
      "tmp": "0.2.7"
    }
  }
}
