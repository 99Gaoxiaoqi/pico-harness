{
  "name": "tiny-claw-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A TypeScript Agent Harness built lesson by lesson from the《从0开始构建Agent Harness》course.",
  "bin": {
    "tiny-claw": "./dist/cli/main.js"
  },
  "scripts": {
    "dev": "tsx src/cli/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --check ."
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.67.0",
    "commander": "^14.0.2",
    "execa": "^9.6.0",
    "pino": "^10.1.0",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
