{
  "name": "pico-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "description": "A TypeScript Agent Harness built lesson by lesson from the《从0开始构建Agent Harness》course.",
  "bin": {
    "pico": "./dist/cli/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx --env-file=.env --import ./src/tui/preload-env.ts src/cli/main.ts",
    "desktop:dev": "npm run start --workspace @pico/desktop",
    "desktop:package": "npm run package --workspace @pico/desktop",
    "desktop:make": "npm run make --workspace @pico/desktop",
    "desktop:typecheck": "npm run typecheck --workspace @pico/desktop",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build:protocol": "npm run build --workspace @pico/protocol",
    "prebuild": "npm run clean && npm run build:protocol",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "node -e \"require('node:fs').chmodSync('dist/cli/main.js',0o755)\"",
    "prepack": "npm run build && npm run smoke:package",
    "smoke:package": "node scripts/package-bin-smoke.mjs",
    "pretypecheck": "npm run build:protocol",
    "typecheck": "tsc --noEmit",
    "check:storage": "node scripts/check-storage-capability.mjs",
    "pretest": "npm run check:storage",
    "test": "vitest run",
    "pretest:e2e": "npm run check:storage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "pretest:llm-e2e": "npm run check:storage",
    "test:llm-e2e": "vitest run --config vitest.llm-e2e.config.ts",
    "test:watch": "vitest",
    "presmoke:tui": "npm run build",
    "smoke:tui": "node scripts/tui-built-smoke.mjs",
    "smoke:tui:source": "node scripts/tui-smoke.mjs",
    "lint": "eslint src tests scripts 'apps/**/*.{ts,tsx}' 'packages/**/*.{ts,tsx}' eslint.config.js vitest.config.ts vitest.e2e.config.ts vitest.llm-e2e.config.ts --no-error-on-unmatched-pattern",
    "format": "prettier --check src tests scripts apps packages .github/workflows docs README.md AGENTS.md package.json package-lock.json tsconfig.json tsconfig.build.json vitest.config.ts vitest.e2e.config.ts vitest.llm-e2e.config.ts"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@pico/protocol": "*",
    "better-sqlite3": "^12.11.1",
    "gpt-tokenizer": "^3.4.0",
    "ink": "^7.1.0",
    "js-yaml": "^5.1.0",
    "pathe": "^2.0.3",
    "picocolors": "^1.1.1",
    "pino": "^10.1.0",
    "react": "^19.2.7",
    "wrap-ansi": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.17",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "node-pty": "^1.1.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.0.16"
  }
}
