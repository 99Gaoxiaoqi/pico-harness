{
  "name": "pico-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A TypeScript Agent Harness built lesson by lesson from the《从0开始构建Agent Harness》course.",
  "bin": {
    "pico": "./dist/cli/main.js"
  },
  "scripts": {
    "dev": "tsx src/cli/main.ts",
    "bench": "tsx src/cli/bench.ts",
    "agentops": "tsx src/cli/main.ts --feishu --plan --trace",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --check ."
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.67.0",
    "better-sqlite3": "^12.11.1",
    "gpt-tokenizer": "^3.4.0",
    "js-yaml": "^5.1.0",
    "pathe": "^2.0.3",
    "pino": "^10.1.0"
  },
  "overrides": {
    "axios": "^1.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.0.3",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.0.16"
  }
}
