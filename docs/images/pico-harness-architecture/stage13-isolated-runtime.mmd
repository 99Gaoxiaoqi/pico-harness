flowchart TB
    A[阶段 13 运行形态]

    subgraph MAIN[主会话]
        T[TUI 宿主] --> M[主 Agent]
        M --> Q{任务类型}
        Q -- 本地工具 --> L[Tool Scheduler]
        Q -- required 委派 --> B[Delegation Barrier]
        L --> O[Observation]
    end

    subgraph WORKER[隔离 worker]
        B --> D[delegate_task]
        D --> W1[独立分支 / worktree]
        W1 --> W2[OS 沙箱与网络策略]
        W2 --> W3[子代理执行]
        W3 --> W4[摘要 / Artifact]
    end

    subgraph MCP[MCP 生命周期]
        R1[Runtime Manager] --> R2[reload / enable / disable]
        R2 --> R3[reconnect / OAuth]
        R3 --> R4[resources / prompts / tools]
    end

    W4 --> G[结果聚合]
    G --> O
    R4 -.-> L
    R4 -.-> D
    O --> S[Session JSONL]
    S --> M

    classDef input fill:#d3f9d8,stroke:#2f9e44,color:#1a1a1a
    classDef process fill:#e5dbff,stroke:#5f3dc4,color:#1a1a1a
    classDef decision fill:#ffe3e3,stroke:#c92a2a,color:#1a1a1a
    classDef action fill:#ffe8cc,stroke:#d9480f,color:#1a1a1a
    classDef output fill:#c5f6fa,stroke:#0c8599,color:#1a1a1a
    classDef storage fill:#fff4e6,stroke:#e67700,color:#1a1a1a

    class A input
    class T,M,B,W3,G,R1,R2,R3 process
    class Q decision
    class L,D,W1,W2,R4 action
    class O,W4 output
    class S storage
